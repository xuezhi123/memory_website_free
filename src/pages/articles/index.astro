---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles");
articles.sort((a, b) => b.data.date.localeCompare(a.data));
---

<BaseLayout title="Memorial Articles" isPrivate>
  <Header privateNav />
  <main class="shell page">
    <h1>Memorial Articles</h1>
    <p class="lead">Words of remembrance from family and friends.</p>
    {
      articles.length === 0 && (
        <p class="lead empty-hint">
          No articles yet. Create a new <code>.md</code> file in{" "}
          <code>src/content/articles/</code> to add one.
        </p>
      )
    }
    <div class="articles">
      {articles.map((entry) => (
        <a class="card" href={`/articles/${entry.slug}`}>
          <time>{entry.data.date}</time>
          <h2>{entry.data.title}</h2>
          {entry.data.excerpt && <p>{entry.data.excerpt}</p>}
        </a>
      ))}
    </div>
  </main>
</BaseLayout>


<style>
  .articles {
    display: grid;
    gap: 16px;
    margin-top: 28px;
  }

  .card {
    display: block;
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 24px 28px;
    background: rgba(255, 255, 255, 0.4);
    transition: border-color 0.2s, background 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.7);
  }

  time {
    font-size: 13px;
    color: #4a5d4a;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  h2 {
    font-size: 22px;
    margin: 6px 0 8px;
    line-height: 1.3;
    color: #4a5d4a;
    font-weight: 700;
  }

  .empty-hint {
    color: var(--muted);
    font-size: 15px;
  }

  .empty-hint code {
    background: var(--soft);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 13px;
  }
</style>
