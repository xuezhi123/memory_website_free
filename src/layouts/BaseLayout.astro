---
import { site } from "../data/site";

interface Props {
  title?: string;
  isPrivate?: boolean;
}

const { title = site.title, isPrivate = false } = Astro.props;
const pageTitle = title === site.title ? title : `${title} | ${site.title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content="A quiet memorial page for family and friends." />
    {isPrivate && <meta name="robots" content="noindex,nofollow" />}
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --paper: #f2ece3;
    --ink: #6a2e2a;
    --muted: #8c8278;
    --line: #dfd8cc;
    --soft: #f2ece3;
    --accent: #8c3e38;
    --accent-dark: #6a2e2a;
    --green: #4a5d4a;
    font-family:
      ui-serif, "Noto Serif SC", "Songti SC", "SimSun", Georgia, serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.75;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  button,
  input {
    font: inherit;
  }

  .shell {
    width: min(100% - 32px, 980px);
    margin: 0 auto;
  }

  .topbar {
    background: var(--accent);
    border-bottom: none;
  }

  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 0;
  }

  .brand {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #f2ece3;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 16px;
    color: rgba(242, 236, 227, 0.85);
    font-size: 14px;
    white-space: nowrap;
  }

  .nav a:hover,
  .nav button:hover {
    color: #f2ece3;
  }

  .nav form {
    display: contents;
  }

  .nav a,
  .nav button {
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
    padding: 6px 0;
  }

  .button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--accent);
    border-radius: 6px;
    background: var(--accent);
    color: white;
    padding: 9px 18px;
    font-weight: 700;
  }

  .button.secondary {
    background: transparent;
    color: var(--accent-dark);
  }

  .page {
    padding: 20px 0 2px;
  }

  .eyebrow {
    color: var(--green);
    font-size: 25px;
    font-weight: 700;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 720px;
    font-size: clamp(34px, 8vw, 70px);
    line-height: 1.08;
    letter-spacing: 2px;
    margin-bottom: 18px;
    color: var(--ink);
  }

  h2 {
    font-size: 28px;
    line-height: 1.25;
    margin-bottom: 16px;
  }

  .lead {
    max-width: 680px;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.8;
  }

  .band {
    border-top: 3px solid var(--accent);
    padding: 36px 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .card {
    border: none;
    border-bottom: 1px solid rgba(140, 130, 120, 0.3);
    border-radius: 0;
    background: var(--paper);
    padding: 18px 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .muted {
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .shell {
      width: min(100% - 24px, 980px);
    }

    .topbar-inner {
      align-items: flex-start;
      flex-direction: column;
    }

    .nav {
      flex-wrap: wrap;
      white-space: normal;
    }

    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
